NODE_ENV=development
BACKEND_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
PORT=8080
COMPANY_TOKEN=qsFj2s8e2XY85oHcNMAvEw

# Limite de memória Node.js (em MB) - PREVENÇÃO OOM
# Para produção com múltiplas sessões WhatsApp, usar 4096 (4GB)
# Para desenvolvimento, 2048 (2GB) é suficiente
NODE_MEMORY_LIMIT=4096

# Turbo Connector (Multi-engine com fallback automático)
TURBO_ENABLED=true
TURBO_MODE=hybrid
TURBO_HEALTH_CHECK_INTERVAL=30000
TURBO_MAX_FAILURES=3
TURBO_BACKOFF_MS=60000

DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whaticket
DB_USER=postgres
DB_PASS=efe487b6a861100fb704ad9f5c160cb8
DB_SSL=false
REDIS_URI_MSG_CONN=redis://127.0.0.1:6379/0
REDIS_URI_ACK=redis://127.0.0.1:6379/0
REDIS_URI=redis://127.0.0.1:6379/0
SOCKET_REDIS_URL=redis://127.0.0.1:6379/0

# Rate Limiter para filas de mensagens (mensagens de chat ao vivo)
# Max mensagens processadas por duration (padrão: 10 mensagens a cada 1 segundo)
REDIS_OPT_LIMITER_MAX=10
REDIS_OPT_LIMITER_DURATION=1000

JWT_SECRET=supersecretjwtkey
SESSIONS_DRIVER=fs
SESSIONS_DIR=private/sessions

# Socket debug/fallback (DEV)
SOCKET_DEBUG=true
SOCKET_FALLBACK_NS_BROADCAST=true

# Configurações de validação WhatsApp (ANTI-BAN PROTECTION)
CONTACT_FILTER_ASYNC_VALIDATION=false
CONTACT_VALIDATION_BATCH_SIZE=50
CONTACT_FILTER_DIRECT_SQL=true
CONTACT_FILTER_VALIDATE_WHATSAPP=false
CONTACT_FILTER_INSERT_CHUNK_SIZE=1000

# ANTI-BAN: Limites de campanha (CONSERVADORES para Baileys - API nao-oficial)
# ATENCAO: Estes valores sao para Baileys. API Oficial pode usar valores maiores.
CAP_HOURLY=30
CAP_DAILY=150
BACKOFF_ERROR_THRESHOLD=3
BACKOFF_PAUSE_MINUTES=15

# ANTI-BAN: Intervalos entre mensagens (em segundos) - CONSERVADORES para Baileys
# ATENCAO: Estes valores sao para Baileys. API Oficial pode usar valores menores.
MESSAGE_INTERVAL_SEC=20
LONGER_INTERVAL_AFTER=10
GREATER_INTERVAL_SEC=300

# ANTI-BAN: Validação automática de contatos (DESABILITAR para evitar sobrecarga)
CONTACT_AUTO_VALIDATE_ON_LIST=false
CONTACT_VALIDATE_TTL_HOURS=168
CONTACT_VALIDATE_MAX_CONCURRENT=3

# SIGNAL AUTO-RECOVERY: Recuperação automática de sessões Signal corrompidas (Bad MAC)
# Threshold de erros de decriptação antes de acionar recovery (aumentado para evitar falsos positivos)
SIGNAL_ERROR_THRESHOLD=20
# Janela de tempo (ms) para acumular erros antes de acionar (aumentado para 60s)
SIGNAL_ERROR_WINDOW_MS=60000
# Máximo de recoveries por hora (proteção contra loops)
SIGNAL_MAX_RECOVERIES_HOUR=2
# Delay (ms) antes de reconectar após limpeza
SIGNAL_RECOVERY_DELAY_MS=5000
